rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             data.trialStartDate is string;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && (
        // Allow updating premium status and billing history
        // In a real app, billing should be handled by server-side functions
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium', 'premiumUntil', 'billingHistory', 'displayName'])
      );
    }
  }
}
