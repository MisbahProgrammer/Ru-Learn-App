rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid is string && 
             data.email is string &&
             data.trialStartDate is timestamp &&
             data.isPremium is bool &&
             data.keys().hasAll(['uid', 'email', 'trialStartDate', 'isPremium']) &&
             data.keys().size() <= 10;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        // Only allow updating specific fields like isPremium or premiumUntil
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPremium', 'premiumUntil', 'scholarshipType', 'displayName'])
      );
    }
  }
}
